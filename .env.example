# Copy to .env and fill in. Never commit .env.
# Get keys from: https://app.alpaca.markets/paper/dashboard/overview

# Note: SECRET_ALPACA_API_KEY holds the Key ID (public-ish identifier).
# SECRET_ALPACA_API_SECRET holds the actual secret string shown once at
# generation time. The naming is local convention, not Alpaca's.
SECRET_ALPACA_API_KEY=
SECRET_ALPACA_API_SECRET=
